# Backend API
PORT=8000

# Local development can use SQLite. Azure should use Azure Database for PostgreSQL.
DATABASE_URL=sqlite:///./cmmc_mvp.db

# Azure PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://cmmc_user:change-me@cmmc-postgres.postgres.database.azure.com:5432/cmmc_pilot?sslmode=require

# Comma-separated frontend origins allowed by FastAPI CORS.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Product data rule for Azure Commercial hosting.
PRODUCT_DATA_RULE=Azure Commercial is not approved for CUI, ITAR, export-controlled data, classified data, or sensitive government contract information.

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
