# Browser-facing API base URL.
# Leave blank when the frontend should call /api and let Next.js proxy to the backend.
NEXT_PUBLIC_API_BASE_URL=

# Server-side Next.js rewrite target for /api.
# Docker Compose:
NEXT_BACKEND_URL=http://backend:8000

# Azure example:
# NEXT_BACKEND_URL=https://your-backend-webapp.azurewebsites.net

# Product data rule shown/enforced by the upload UI and backend.
PRODUCT_DATA_RULE=Azure Commercial is not approved for CUI, ITAR, export-controlled data, classified data, or sensitive government contract information.
